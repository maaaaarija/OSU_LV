import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, Input

# --- PRIPREMA KAO U TEMPLATE 1 ---
# Napomena: Ako je multiklasna (npr. 3 klase), koristi:
# y = tf.keras.utils.to_categorical(y)

model = Sequential([
    Input(shape=(X_train.shape[1],)), # Automatski uzima broj ulaza
    Dense(12, activation='relu'),
    Dense(8, activation='relu'),
    # ZA BINARNU (0/1):
    Dense(1, activation='sigmoid') 
    # ZA MULTIKLASNU (3 klase):
    # Dense(3, activation='softmax')
])

# KOMPILACIJA
# Za binarnu: loss='binary_crossentropy'
# Za multiklasnu: loss='categorical_crossentropy'
model.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])

# TRENING
history = model.fit(X_train, y_train, epochs=150, batch_size=10, validation_split=0.1)

# EVALUACIJA I SPREMANJE
model.save('moj_model.keras')
# loss_plot
plt.plot(history.history['loss'])
plt.title('Model Loss tijekom treninga')
plt.show()








